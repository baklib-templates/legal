{% assign default_light_logo = "data:image/png;base64," %}
{% assign default_dark_logo = "data:image/png;base64," %}
{% assign light_logo = site.settings.logo_url | default: default_light_logo %}
{% assign dark_logo = site.settings.dark_logo_url | default: default_dark_logo %}
<nav id="topnav" class="backdrop-blur-sm">
  <div class="container relative flex justify-between items-center">
    <a class="logo" href="/">
      <img class="inline-block dark:hidden h-[40px] max-w-[150px] object-contain hover:object-scale-down" src="{{ light_logo }}">
      <img class="hidden dark:inline-block h-[40px] max-w-[150px] object-contain hover:object-scale-down" src="{{ dark_logo }}">
    </a>
    <ul class="list-none mb-0">
      <li class="inline-block relative">
        <button class="btn btn-circle btn-sm btn-ghost font-extralight" type="button">
          <i class="ri-search-line text-xl"></i>
        </button>
      </li>
      <li class="dropdown inline-block relative">
        <button class="avatar" type="button">
          <div class="w-8 rounded-full">
            <img src="{{ "images/demos/video/avatar-01.jpg" | asset_url }}">
          </div>
        </button>
        <div
          class="dropdown-menu absolute end-0 m-0 mt-4 z-10 w-44 rounded-md overflow-hidden bg-base-100 shadow dark:shadow-gray-700 hidden">
          <ul class="py-2 text-start">
            <li><a
                class="flex items-center font-medium py-2 px-4 dark:text-white/70 hover:text-primary dark:hover:text-white"
                href="/grid" data-discover="true"><svg stroke="currentColor" fill="none" stroke-width="2"
                  viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="size-4 me-2" height="1em"
                  width="1em" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>Profile</a></li>
            <li><a
                class="flex items-center font-medium py-2 px-4 dark:text-white/70 hover:text-primary dark:hover:text-white"
                href="/grid" data-discover="true"><svg stroke="currentColor" fill="none" stroke-width="2"
                  viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="size-4 me-2" height="1em"
                  width="1em" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="3"></circle>
                  <path
                    d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z">
                  </path>
                </svg>Settings</a></li>
            <li class="border-t border-gray-100 dark:border-gray-800 my-2"></li>
            <li><a
                class="flex items-center font-medium py-2 px-4 dark:text-white/70 hover:text-primary dark:hover:text-white"
                href="/grid" data-discover="true"><svg stroke="currentColor" fill="none" stroke-width="2"
                  viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="size-4 me-2" height="1em"
                  width="1em" xmlns="http://www.w3.org/2000/svg">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>Lockscreen</a></li>
            <li><a
                class="flex items-center font-medium py-2 px-4 dark:text-white/70 hover:text-primary dark:hover:text-white"
                href="/grid" data-discover="true"><svg stroke="currentColor" fill="none" stroke-width="2"
                  viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="size-4 me-2" height="1em"
                  width="1em" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                  <polyline points="16 17 21 12 16 7"></polyline>
                  <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>Logout</a></li>
          </ul>
        </div>
      </li>
    </ul>
  </div>
</nav>