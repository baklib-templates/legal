{% comment %}
博客列表页的卡片
参数：
- page: 博客页面
{% endcomment %}
<div class="overflow-hidden relative shadow card bg-base-100">
  <div class="overflow-hidden relative">
    {% if page.settings.thumb_image_url %}
      <img class="object-cover object-center w-full duration-500 group-hover:scale-105 aspect-video" alt="" src="{{ page.settings.thumb_image_url }}">
    {% endif %}
    <div class="absolute bottom-6 start-6">
      {% for tag in page.settings.tags %}
        <a class="bg-primary text-white text-[12px] px-2.5 py-1 rounded-md h-4 mx-[2px]" href="?tag={{ tag.name }}">{{ tag.name }}</a>
      {% endfor %}
    </div>
  </div>
  <div class="relative p-6">
      <div class="flex justify-between mb-4"><span class="flex items-center text-sm text-base-content/40"><svg
            stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round"
            stroke-linejoin="round" class="size-4 me-1" height="1em" width="1em"
            xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg> {{ page.published_at | date: "%Y-%m-%d" }}</span><span class="flex items-center text-sm text-base-content/40"><svg
            stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round"
            stroke-linejoin="round" class="size-4 me-1" height="1em" width="1em"
            xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg> {{ page.settings.reading_time }} </span>
      </div>
      <a class="text-lg font-medium hover:text-primary" href="{{ page.path }}" data-discover="true">{{ page.settings.title }}</a>
      <div class="mt-3"><a
          class="duration-500 ease-in-out btn btn-link hover:text-primary-600 after:bg-primary-600"
          href="{{ page.path }}" data-discover="true"> 阅读详情 <i class="mdi mdi-arrow-right"></i></a>
      </div>
  </div>
</div>
