{% comment %}
  视频首页的视频卡片组件
  参数:
  - page: 视频课程页面数据
  - default_cover: 默认封面图
{% endcomment %}

{% assign default_cover = default_cover | presence %}
{% unless default_cover %}
  {% assign default_cover = "images/demos/video/video-preview-01.jpg" | asset_url %}
{% endunless %}

<div class="group bg-base-100 rounded-md shadow-md hover:shadow-lg shadow-base-200 dark:shadow-none transition duration-500 w-full mx-auto">
  <div class="md:flex">
    <div class="p-3 md:pe-0 md:pb-3 pb-0 relative md:shrink-0">
      <img class="rounded-md size-full object-cover md:w-48" src="{{ page.settings.cover | default: default_cover }}">
      <div class="absolute start-6 top-6">
        {% for tag in page.settings.tags %}
          <a class="bg-primary text-white text-[12px] px-2.5 py-1 rounded-md h-4 mx-[2px]" href="?tag={{ tag.name }}">{{ tag.name }}</a>
        {% endfor %}
      </div>
    </div>
    <div class="p-6 w-full">
      <div class="flex mb-3">
        <span class="text-slate-400 text-sm flex items-center">
          <i class="ri-timer-line text-slate-50 mr-0.5"></i>
          {{ page.settings.duration }}
        </span>
        <span class="text-slate-400 text-sm flex items-center ms-3">
          <i class="ri-group-line text-base-content mr-0.5"></i>
          {{ page.visits_count }}
        </span>
      </div>
      {% comment %} title {% endcomment %}
      <a class="text-lg hover:text-primary font-medium" href="{{ page.path }}">{{ page.link_text }}</a>
      {% comment %} description {% endcomment %}
      <p class="text-slate-400 mt-2">{{ page.settings.description }}</p>
      <div class="flex justify-between md:mt-12 mt-3">
        <div class="flex items-center">
          <div class="avatar">
            <div class="w-8 rounded-full shadow shadow-base-200 me-2">
              <img src="{{ page.author.avatar_path }}" />
            </div>
          </div>
          <span class="font-medium">
            {{ page.author.name }}
          </span>
        </div>
        <a class="btn btn-soft btn-primary btn-sm" href="{{ page.path }}">Explore
          <i class="ri-arrow-right-line align-middle ms-1"></i>
        </a>
      </div>
    </div>
  </div>
</div>