{%- comment -%}
  视频播放器组件
  参数：
  - video_url: 视频地址
  - poster: 视频封面图（可选）
  - title: 视频标题（可选）
  - autoplay: 是否自动播放（可选，默认false）
  - loop: 是否循环播放（可选，默认false）
  - muted: 是否静音（可选，默认false）
{%- endcomment -%}

<div class="video-player-wrapper relative w-full bg-black rounded-lg overflow-hidden group" 
  x-data="videoPlayer()"
  x-init="init"
>
  <video
    class="w-full aspect-video"
    :class="{ 'cursor-pointer': !isPlaying }"
    :src="'{{ video_url }}'"
    :autoplay="{{ autoplay | default: false }}"
    :loop="{{ loop | default: false }}"
    :muted="{{ muted | default: false }}"
    preload="metadata"
    data-poster="{{ poster | default: '' }}"
    @click="togglePlay"
    @timeupdate="updateProgress"
    @loadedmetadata="setDuration"
    @loadeddata="onVideoLoaded"
    @ended="onVideoEnd"
    x-ref="video"
  ></video>

  <!-- 加载状态 -->
  <div 
    class="absolute inset-0 flex items-center justify-center bg-black/50"
    x-show="!isVideoLoaded"
  >
    <div class="animate-spin rounded-full h-12 w-12 border-4 border-primary border-t-transparent"></div>
  </div>
  {%- if title -%}
    <div class="absolute top-0 left-0 right-0 p-4 bg-gradient-to-b from-black/60 to-transparent">
      <h3 class="text-white text-lg font-medium">{{ title }}</h3>
    </div>
  {%- endif -%}

  <!-- 播放按钮 -->
  <div 
    class="absolute inset-0 flex items-center justify-center transition-opacity duration-300"
    :class="{ 'opacity-0': isPlaying, 'opacity-100': !isPlaying }"
    @click="togglePlay"
  >
    <button class="cursor-pointer w-20 h-20 bg-black/20 hover:bg-primary rounded-full flex items-center justify-center backdrop-blur-sm transition-colors">
      <i class="ri-play-fill text-white text-4xl"></i>
    </button>
  </div>

  <!-- 控制栏 -->
  <div 
    class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent transition-opacity duration-300"
    :class="{ 'opacity-0 group-hover:opacity-100': isPlaying }"
  >
    <!-- 进度条 -->
    <div class="relative h-1 bg-white/20 rounded-full mb-4 cursor-pointer" @click="seekVideo">
      <div class="absolute h-full bg-primary rounded-full" :style="{ width: progress + '%' }"></div>
      <div 
        class="absolute h-3 w-3 bg-primary rounded-full -top-1 transform -translate-x-1/2"
        :style="{ left: progress + '%' }"
      ></div>
    </div>

    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-4">
        <!-- 播放/暂停按钮 -->
        <button @click="togglePlay" class="cursor-pointer text-white hover:text-primary transition-colors">
          <i class="ri-play-fill text-xl" x-show="!isPlaying"></i>
          <i class="ri-pause-fill text-xl" x-show="isPlaying"></i>
        </button>

        <!-- 音量控制 -->
        <button @click="toggleMute" class="cursor-pointer text-white hover:text-primary transition-colors">
          <i class="ri-volume-up-fill text-xl text-white" x-show="!isMuted && volume > 0.5"></i>
          <i class="ri-volume-down-fill text-xl text-white" x-show="!isMuted && volume <= 0.5"></i>
          <i class="ri-volume-mute-fill text-xl text-white" x-show="isMuted"></i>
        </button>

        <!-- 时间显示 -->
        <div class="text-white text-sm">
          <span x-text="formatTime(currentTime)"></span>
          /
          <span x-text="formatTime(duration)"></span>
        </div>
      </div>

      <div class="flex items-center space-x-4">
        <!-- 全屏按钮 -->
        <button @click="toggleFullscreen" class="cursor-pointer text-white hover:text-primary transition-colors">
          <i class="ri-fullscreen-fill text-xl"></i>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .video-player-wrapper input[type="range"] {
    -webkit-appearance: none;
    @apply h-1 bg-white/20 rounded-full;
  }

  .video-player-wrapper input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    @apply w-3 h-3 bg-primary rounded-full cursor-pointer;
  }

  .video-player-wrapper input[type="range"]::-moz-range-thumb {
    @apply w-3 h-3 bg-primary rounded-full cursor-pointer border-0;
  }
</style>