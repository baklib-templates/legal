<section class="relative overflow-hidden md:py-44 py-36">
  <div class="container relative md:mt-16 mt-6">
    <div class="grid lg:grid-cols-12 md:grid-cols-2 grid-cols-1 items-center gap-6">
      <div class="lg:col-span-7">
        <h6 class="text-yellow-500 font-semibold mb-3 uppercase">80% Satisfaction Guarantee</h6>
        <h1 class="font-bold lg:leading-normal leading-normal tracking-wide text-4xl lg:text-5xl mb-5">Learn
          Product Design <br> in <span
            class="bg-gradient-to-l from-fuchsia-500 to-violet-600 text-transparent bg-clip-text">16
            weeks</span></h1>
        <p class="text-slate-400 text-lg max-w-xl">Discover a world of knowledge and opportunities with our
          online education platform pursue a new career.</p>
        <div class="mt-6"><a
            class="h-10 px-6 tracking-wide inline-flex items-center justify-center font-medium rounded-md bg-primary text-white"
            href="/index-five" data-discover="true">Explore Courses <i
              class="ri-arrow-right-line align-middle ms-1"></i></a><a
            class="size-10 inline-flex items-center justify-center tracking-wide align-middle duration-500 text-base text-center rounded-full bg-primary/10 hover:bg-primary text-primary hover:text-white ms-1 lightbox"
            href="/index-five#!" data-discover="true"><svg stroke="currentColor" fill="none" stroke-width="2"
              viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" height="1em"
              width="1em" xmlns="http://www.w3.org/2000/svg">
              <polygon points="23 7 16 12 23 17 23 7"></polygon>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
            </svg></a><span class="font-medium text-base-content/50 ms-1 align-middle"> Watch
            Now</span></div>
      </div>
      <div class="lg:col-span-5">
        <div class="grid grid-cols-2 gap-6">
          <div class="relative md:shrink-0"><img
              class="xl:size-56 lg:size-44 md:size-40 size-44 object-cover shadow shadow-base-200 rounded-s-full"
              alt="" src="{{ 'images/demos/1.jpg' | asset_url }}">
              100% Satisfaction Guarantee
            <div
              class="overflow-hidden after:content-[''] after:absolute after:size-12 after:bg-secondary after:top-0 after:-start-6 after:-z-1 after:rounded-full">
            </div>
          </div>
          <div class="relative md:shrink-0"><img
              class="xl:size-56 lg:size-44 md:size-40 size-44 object-cover shadow shadow-base-200 rounded-full"
              alt="" src="{{ 'images/demos/video/2-D_X1zCGw.jpg' | asset_url }}">
            <div
              class="overflow-hidden after:content-[''] after:absolute after:size-24 after:bg-primary/40 after:-top-10 after:-end-0 after:-z-1 after:rounded-lg after:rotate-[36deg]">
            </div>
          </div>
          <div class="relative md:shrink-0"><img
              class="xl:size-56 lg:size-44 md:size-40 size-44 object-cover shadow shadow-base-200 rounded-xl"
              alt="" src="{{ 'images/demos/video/3-DCQogip7.jpg' | asset_url }}">
            <div
              class="overflow-hidden after:content-[''] after:absolute after:size-40 after:bg-yellow-400 after:-bottom-10 after:-start-10 after:-z-1 after:rounded-full">
            </div>
          </div>
          <div class="relative md:shrink-0"><img
              class="xl:size-56 lg:size-44 md:size-40 size-44 object-cover shadow shadow-base-200 rounded-e-full"
              alt="" src="{{ 'images/demos/video/4-HDGskMOh.jpg' | asset_url }}">
            <div
              class="overflow-hidden after:content-[''] after:absolute after:size-6 after:bg-primary/60 after:bottom-10 after:-end-12 after:-z-1 after:rounded-md">
            </div>
            <div
              class="overflow-hidden after:content-[''] after:absolute after:size-6 after:bg-secondary/60 after:-bottom-12 after:start-10 after:-z-1 after:rounded-full">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="relative py-12 bg-primary">
  <div class="container relative">
    <div class="grid lg:grid-cols-12 grid-cols-1 md:text-start text-center justify-center">
      <div class="lg:col-start-2 lg:col-span-10">
        <div class="grid md:grid-cols-4 sm:grid-cols-2 grid-cols-2 items-center gap-6">
          <div class="counter-box text-center">
            <h1 class="text-white lg:text-4xl text-3xl font-semibold mb-2"><span>1,548</span>+</h1>
            <h5 class="counter-head text-white uppercase font-medium">Courses</h5>
          </div>
          <div class="counter-box text-center">
            <h1 class="text-white lg:text-4xl text-3xl font-semibold mb-2"><span>12</span>+</h1>
            <h5 class="counter-head text-white uppercase font-medium">Countries</h5>
          </div>
          <div class="counter-box text-center">
            <h1 class="text-white lg:text-4xl text-3xl font-semibold mb-2"><span>500</span>K</h1>
            <h5 class="counter-head text-white uppercase font-medium">Students</h5>
          </div>
          <div class="counter-box text-center">
            <h1 class="text-white lg:text-4xl text-3xl font-semibold mb-2"><span>80</span>+</h1>
            <h5 class="counter-head text-white uppercase font-medium">Instructors</h5>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="relative md:py-24 py-16">
