{%- comment -%}
  Root `/` landing page.
  - Auto-redirect is handled by `snippets/_locale_redirect.liquid` in layout.
  - This page renders a minimal fallback language chooser + search.
{%- endcomment -%}

{%- assign supported_raw = site.settings.supported_language_prefixes | default: 'en,zh' -%}
{%- assign supported = supported_raw | split: ',' -%}

<div class="flex-1 bg-white">
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
    <header class="space-y-6">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">
        {{ site.settings.brand_name | default: site.name | default: 'Legal Hub' }}
      </h1>
      <p class="text-base leading-relaxed text-slate-600">
        {{ site.settings.home_intro | default: ('legal.home.intro' | t) }}
      </p>
      <div>
        {% render 'search_box' %}
      </div>
    </header>

    <section class="mt-10 rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <div class="text-sm font-medium text-slate-900">{{ 'legal.home.choose_language' | t }}</div>
      <div class="mt-4 flex flex-wrap gap-2">
        {%- for l in supported -%}
          {%- assign lang = l | strip -%}
          {%- if lang != blank -%}
            <a
              class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
              href="/{{ lang }}/"
              onclick="try{localStorage.setItem('legalhub:lang','{{ lang }}');localStorage.setItem('legalhub:lang_locked','1')}catch(e){}"
            >{{ lang }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <p class="mt-4 text-xs text-slate-500">{{ 'legal.home.redirect_note' | t }}</p>
    </section>
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.index.name",
    "thumb_url": "images/theme/${lang}/cover.png",
    "preview_image_urls": [
      "images/theme/${lang}/index_poster.png"
    ],
    "description": "t:schema.templates.index.description",
    "sub_page_templates": ["language"]
  }
{% endschema %}
