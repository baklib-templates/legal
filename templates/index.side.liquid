{%- comment -%}
  Root `/` landing page (side navigation layout).
  Keep the same functionality as index.liquid:
  - Search box
  - Language chooser + localStorage preference
  - Redirect note (actual redirect handled in layout via locale_redirect)
{%- endcomment -%}

{%- assign supported_raw = site.settings.supported_language_prefixes | default: 'en,zh' -%}
{%- assign supported = supported_raw | split: ',' -%}

<div class="flex-1 bg-white">
  <div class="mx-auto flex max-w-7xl gap-10 px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <aside class="hidden w-60 shrink-0 lg:block">
      <div class="sticky top-24 space-y-8">
        <div>
          <div class="text-sm font-semibold text-slate-900">
            {{ site.settings.brand_name | default: site.name | default: 'Legal Hub' }}
          </div>
          <div class="mt-2 space-y-1 text-sm text-slate-600">
            <a href="#choose-language" class="block hover:text-slate-900">{{ 'legal.home.choose_language' | t }}</a>
            <a href="#search" class="block hover:text-slate-900">{{ 'generic.placeholders.search' | t }}</a>
            <a href="#about" class="block hover:text-slate-900">{{ 'legal.nav.home' | t }}</a>
          </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">{{ 'legal.home.choose_language' | t }}</div>
          <div class="mt-3 flex flex-wrap gap-2">
            {%- for l in supported -%}
              {%- assign lang = l | strip -%}
              {%- if lang != blank -%}
                <a
                  class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50"
                  href="/{{ lang }}/"
                  onclick="try{localStorage.setItem('legalhub:lang','{{ lang }}');localStorage.setItem('legalhub:lang_locked','1')}catch(e){}"
                >{{ lang }}</a>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <p class="mt-3 text-xs text-slate-500">{{ 'legal.home.redirect_note' | t }}</p>
        </div>
      </div>
    </aside>

    <main class="min-w-0 flex-1">
      <header class="space-y-4">
        <h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">
          {{ site.settings.brand_name | default: site.name | default: 'Legal Hub' }}
        </h1>
        <p id="about" class="max-w-[80ch] text-base leading-relaxed text-slate-600">
          {{ site.settings.home_intro | default: ('legal.home.intro' | t) }}
        </p>

        <div id="search" class="pt-2">
          {% render 'search_box' %}
        </div>
      </header>

      <section id="choose-language" class="mt-10 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="text-sm font-semibold text-slate-900">{{ 'legal.home.choose_language' | t }}</div>
        <div class="mt-4 flex flex-wrap gap-2">
          {%- for l in supported -%}
            {%- assign lang = l | strip -%}
            {%- if lang != blank -%}
              <a
                class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
                href="/{{ lang }}/"
                onclick="try{localStorage.setItem('legalhub:lang','{{ lang }}');localStorage.setItem('legalhub:lang_locked','1')}catch(e){}"
              >{{ lang }}</a>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <p class="mt-4 text-xs text-slate-500">{{ 'legal.home.redirect_note' | t }}</p>
      </section>
    </main>
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.index_side.name",
    "thumb_url": "images/theme/${lang}/cover.png",
    "preview_image_urls": [
      "images/theme/${lang}/index_poster.png"
    ],
    "description": "t:schema.templates.index_side.description",
    "sub_page_templates": ["language"]
  }
{% endschema %}

