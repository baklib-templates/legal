{% comment %}
导航网址首页模板（daisyUI 版）
{% endcomment %}

<div class="flex container min-h-screen pt-[64px] -pt-[calc(var(--header-height))] bg-base-100"
  x-data="{
    selected: {},
    onSelect: function(categoryId, tagName = 'hot', scrollTo = false) {
      if (scrollTo) {
        document.getElementById('category-' + categoryId).scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      this.selected = {
        categoryId: categoryId,
        tagName: tagName
      }
    }
  }"
>
  <!-- 左侧导航 -->
  <aside class="w-64 pb-4 pt-1 bg-base-100 border-r border-base-200">
    <nav class="sticky top-[calc(var(--header-height))] max-h-[calc(100vh-var(--header-height)-4rem)]">
      <ul class="space-y-2" x-data="{openId: ''}" x-init="selected = { categoryId: '', tagName: '' }">
        {% for category in page.children_in_nav_menu %}
          {% assign filter_tags = category.settings.tags %}
          {% assign filter_tags_count = filter_tags | size %}

          {% query hot_pages from category.children %}
          {
          "where": {
          "settings.hot_eq": true
          }
          }
          {% endquery %}
          {% assign hot_pages_count = hot_pages | size %}

          <li x-data="{ tag_items: false }" class="relative">
            <button
              @click.prevent="onSelect('{{ category.id }}', '{% if hot_pages_count > 0 %}hot{% endif %}', true);  openId = openId === '{{ category.id }}' ? '' : '{{ category.id }}'"
              class="flex items-center justify-between w-full px-4 py-2 rounded-lg hover:bg-primary fill-base-100 hover:text-base-100 hover:fill-base-100 cursor-pointer"
              :class="selected.categoryId === '{{ category.id }}' ? 'bg-primary text-base-100' : 'bg-base-100 fill-base-content'">
              <div class="flex items-center gap-2">
                <span class='w-4 h-4 inline-block'>
                  {% if category.settings.icon %}
                  <img src="{{ category.settings.icon }}" class="w-4 h-4">
                  {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path
                      d="M20.0833 15.1999L21.2854 15.9212C21.5221 16.0633 21.5989 16.3704 21.4569 16.6072C21.4146 16.6776 21.3557 16.7365 21.2854 16.7787L12.5144 22.0412C12.1977 22.2313 11.8021 22.2313 11.4854 22.0412L2.71451 16.7787C2.47772 16.6366 2.40093 16.3295 2.54301 16.0927C2.58523 16.0223 2.64413 15.9634 2.71451 15.9212L3.9166 15.1999L11.9999 20.0499L20.0833 15.1999ZM20.0833 10.4999L21.2854 11.2212C21.5221 11.3633 21.5989 11.6704 21.4569 11.9072C21.4146 11.9776 21.3557 12.0365 21.2854 12.0787L11.9999 17.6499L2.71451 12.0787C2.47772 11.9366 2.40093 11.6295 2.54301 11.3927C2.58523 11.3223 2.64413 11.2634 2.71451 11.2212L3.9166 10.4999L11.9999 15.3499L20.0833 10.4999ZM12.5144 1.30864L21.2854 6.5712C21.5221 6.71327 21.5989 7.0204 21.4569 7.25719C21.4146 7.32757 21.3557 7.38647 21.2854 7.42869L11.9999 12.9999L2.71451 7.42869C2.47772 7.28662 2.40093 6.97949 2.54301 6.7427C2.58523 6.67232 2.64413 6.61343 2.71451 6.5712L11.4854 1.30864C11.8021 1.11864 12.1977 1.11864 12.5144 1.30864ZM11.9999 3.33233L5.88723 6.99995L11.9999 10.6676L18.1126 6.99995L11.9999 3.33233Z">
                    </path>
                  </svg>
                  {% endif %}
                </span>
                <span>{{ category.settings.title }}</span>
              </div>
              <template x-if="tag_items">
                <svg xmlns="http://www.w3.org/2000/svg"
                  class="w-3.5 h-3.5 inline-block -rotate-90 transition duration-200 ease-in-out" fill="none"
                  viewBox="0 0 24 24" stroke="currentColor" data-name="chevron_down" data-style="outline"
                  :class="openId === '{{ category.id }}' ? 'rotate-0' : ''">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </template>
            </button>
            {% if filter_tags_count > 0 %}
            <ul class="mt-1 space-y-1" x-init="tag_items = true" x-show="openId === '{{ category.id }}'" x-cloak>
              {% for tag in filter_tags %}
              <li class='pl-8 hover:bg-primary/50 rounded-lg hover:text-base-100'>
                <a class="block py-2 hover:underline cursor-pointer"
                  @click.prevent="onSelect('{{ category.id }}', '{{ tag.name }}', true)">{{ tag.name }}</a>
              </li>
              {% endfor %}
            </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  </aside>
  <!-- 右侧内容 -->
  <main class="flex-1 p-8 pt-1">
    {% for category in page.children_in_nav_menu %}
      <section class="mb-12" id="category-{{ category.id }}"
        x-data="{ activeTab: '' }"
        x-init="$watch('selected', function(newValue) {
          if (newValue.categoryId === '{{ category.id }}') {
            activeTab = newValue.tagName;
          }
        })"
      >
        <div class="flex items-center mb-4">
          <h2 class="text-2xl font-bold mr-4">{{ category.settings.title }}</h2>
          <div class="flex gap-2">
            {% query hot_pages from category.children %}
              {
                "where": {
                  "settings.hot_eq": true
                }
              }
            {% endquery %}
            {% assign hot_pages_count = hot_pages | size %}

            {% if hot_pages_count > 0 %}
              <div class="text-xs px-3 py-1 bg-none hover:bg-primary/40 hover:text-base-100 rounded-full cursor-pointer"
                :class="activeTab == 'hot' ? 'bg-primary/80 text-base-100' : 'text-base-content'"
                @click="onSelect('{{ category.id }}', 'hot', true)"
                x-init="activeTab = 'hot'"
              >
              {{  page.settings.hot_filter_label }}
              </div>
            {% endif %}

            {% for tag in category.settings.tags %}
              <div class="text-xs px-3 py-1 bg-none hover:bg-primary/40 hover:text-base-100 rounded-full cursor-pointer"
                :class="activeTab === '{{ tag.name }}' ? 'bg-primary/80 text-base-100' : 'text-base-content'"
                @click="
                  onSelect('{{ category.id }}', '{{ tag.name }}', true)
                "
              >{{ tag.name }}</div>
            {% endfor %}
          </div>
        </div>
        <div class="flex flex-wrap gap-6">
          {% for category_page in category.children %}
            {% assign page_tags = page.settings.tags | map: 'name' | join: '\n' %}
            <a
              class="card w-72 bg-base-100 shadow-md border border-base-200 transition duration-200 ease-in-out hover:shadow-lg hover:translate-y-[-2px] group"
              href="{{ category_page.settings.external_link }}"
              target="_blank"
              title="{{ category_page.settings.title }}"
              x-show="!activeTab || (activeTab === 'hot' && {{category_page.settings.hot}}) || '{{ page_tags }}'.split('\n').includes(activeTab)"
              x-cloak
            >
              <div class="card-body">
                <div class='flex items-center space-x-2 justify-start mb-2'>
                  {% if category_page.settings.icon %}
                    <img src="{{ category_page.settings.icon }}" class="h-8"/>
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-10 w-10 h-10 text-primary dark:text-base-100">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 6.878V6a2.25 2.25 0 0 1 2.25-2.25h7.5A2.25 2.25 0 0 1 18 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 0 0 4.5 9v.878m13.5-3A2.25 2.25 0 0 1 19.5 9v.878m0 0a2.246 2.246 0 0 0-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0 1 21 12v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6c0-.98.626-1.813 1.5-2.122" />
                    </svg>
                  {% endif %}
                  <h3 class="card-title text-lg group-hover:text-primary transition duration-200 ease-in-out group-hover:underline group-hover:decoration-primary group-hover:decoration-2 group-hover:underline-offset-4
                  ">{{ category_page.settings.title }}</h3>
                </div>
                <p class="text-accent-content text-sm mb-2 line-clamp-1">{{ category_page.settings.description }}</p>
                <!-- 可补充更多内容，如链接、图片等 -->
              </div>
            </a>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </main>
</div>

{% schema %}
{
  "name": "t:schema.templates.index.link-directory.name",
  "description": "t:schema.templates.index.link-directory.description",
  "thumb_url": "images/theme/link-directory.png",
  "preview_image_urls": [
    "images/theme/link-directory.png"
  ],
  "sub_page_templates": ["link-directory-list", "blank"],
  "settings": [
    {
			"id": "hot_filter_label",
			"type": "text",
			"label": "t:schema.templates.link-directory-list.settings.hot_filter_label.label",
			"info": "t:schema.templates.link-directory-list.settings.hot_filter_label.info",
      "default": "t:schema.templates.link-directory-list.settings.hot_filter_label.default"
		}
  ]
}
{% endschema %}
