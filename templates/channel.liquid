{%- comment -%}
  Channel page under a language root: `/<lang>/<channel>/`
  Lists children policies.
{%- endcomment -%}

{%- assign children = page.children_in_list | order_by: '-published_at' -%}

<div class="flex-1 bg-white">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <header class="mb-10 space-y-4 border-b border-slate-200 pb-10">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">{{ page.link_text }}</h1>
      {%- if page.settings.description -%}
        <div class="max-w-3xl text-base leading-relaxed text-slate-600">{{ page.settings.description }}</div>
      {%- endif -%}
    </header>

    {% render 'children_list', pages: children %}
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.channel.name",
    "thumb_url": "images/theme/index-card.png",
    "preview_image_urls": [
      "images/theme/index-card.png"
    ],
    "description": "t:schema.templates.channel.description",
    "sub_page_templates": ["page"],
    "settings": [
      {
        "id": "description",
        "type": "textarea",
        "to_markdown": true,
        "label": "t:schema.templates.channel.settings.description.label"
      }
    ]
  }
{% endschema %}

